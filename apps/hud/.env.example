# Required: shared secret for POST /api/events.
# Generate a random 32-byte hex token with:
#   pnpm hud:token
# The script writes the value to apps/hud/.env.local (gitignored). Never commit
# the real token. Never expose it to the browser.
HUD_INGEST_TOKEN=replace-me-with-pnpm-hud-token-output

# Optional: in-memory ring-buffer capacity for the live event bus.
# Default: 1000. Must be >= 1; non-numeric values fall back to the default.
HUD_BUS_SIZE=1000

# Optional: port the HUD dev/start scripts listen on.
# Default: 4000. Override only if 4000 is occupied on your machine. Consumed by
# the pnpm script line (next dev -p ${HUD_PORT:-4000}); does not affect the app
# runtime itself.
# HUD_PORT=5000

# Optional: SSE backpressure — maximum bytes allowed in the SSE write queue
# before the slow-consumer grace timer starts. Default: 1048576 (1 MB).
# Non-positive or non-numeric values fall back to the default.
# HUD_SSE_BACKPRESSURE_BYTES=1048576

# Optional: SSE backpressure — seconds of sustained backpressure before a
# slow consumer is disconnected. Default: 30. Non-positive or non-numeric
# values fall back to the default.
# HUD_SSE_BACKPRESSURE_GRACE_S=30

# Optional: maximum size (MB) of each JSONL event log file before it is
# rotated. Three rotated generations are kept. Default: 100.
# On a Raspberry Pi SD card, lower this (e.g. 10) to reduce wear.
# HUD_LOG_MAX_SIZE_MB=100

# Optional: number of days to keep rotated JSONL log files. Files whose
# mtime exceeds this window are deleted on the next rotation. Default: 7.
# Set to 0 to delete rotated files immediately after each rotation.
# HUD_LOG_RETENTION_DAYS=7

# Optional: set to 1 to forward poller stdout/stderr to the parent process
# stdout/stderr in addition to the dedicated log files in logs/. Useful for
# development. Default: unset (logs go to files only).
# HUD_ENABLE_POLLER_LOG_PASSTHROUGH=1

# Optional: set to 1 to skip spawning the sessions sidecar poller. The
# Sessions panel will remain empty. Default: unset.
# HUD_DISABLE_POLLER=1

# Optional: set to 1 to skip spawning the transcript sidecar poller. The
# Tokens / Cost / Context cards will remain empty. Default: unset.
# HUD_DISABLE_TRANSCRIPT_POLLER=1

# Optional: agent event-deduplication cache TTL in minutes. The HUD caches the
# most-recently-seen agent.invoke payload per (sessionId, agentName) pair to
# suppress duplicate events emitted by rapid hook re-fires. Default: 60.
# Increase if you see agents disappearing from the live view unexpectedly.
# Decrease (e.g. 5) in development to speed up cache refresh during testing.
# HUD_AGENT_CACHE_TTL_MIN=60

# ---------------------------------------------------------------------------
# Tuning notes
# ---------------------------------------------------------------------------
# When to adjust each variable:
#
# HUD_BUS_SIZE               Increase (e.g. 5000) for long-running sessions
#                            where the 24 h cost chart needs more history; decrease
#                            on memory-constrained hardware.
#
# HUD_LOG_MAX_SIZE_MB        Lower to 10 on Raspberry Pi SD cards to reduce write
#                            wear. Each JSONL file rotates at this ceiling; three
#                            rotated generations are kept.
#
# HUD_LOG_RETENTION_DAYS     Set to 1 for aggressive disk cleanup. Set to 0 to
#                            delete rotated files immediately after each rotation.
#
# HUD_SSE_BACKPRESSURE_*     If the HUD disconnects slow consumers (watch for
#                            bp-disconnect in DevTools), raise GRACE_S to give
#                            clients more time before ejection.
#
# HUD_AGENT_CACHE_TTL_MIN    Raise if agents vanish from the live view mid-session
#                            due to cache expiry. Lower in development to shorten
#                            the feedback loop when testing hook payloads.
#
# HUD_DISABLE_POLLER /       Set to 1 in unit-test environments or on machines
# HUD_DISABLE_TRANSCRIPT_POLLER  that do not have ~/.claude/sessions/ accessible.
#
# See TROUBLESHOOTING.md for step-by-step diagnostic guides.
